# DEMORUN environment — copy to .env and fill in. NEVER commit .env.
# This file (.env.example) IS committed, so it must contain placeholders only.

# --- Server ---
PORT=3000
PUBLIC_BASE_URL=            # e.g. https://demorun.moren.xyz — used to build result_url
DATABASE_PATH=./data/demorun.db

# --- Payments (x402 / OKX) ---
PAYMENTS_ENFORCED=false     # Phase 1: false. Flip to true in Phase 3 once x402 is real.
PRICE_USDT=1.5             # raised from 1 after Phase 0: all-video COGS ~$0.54 (see PHASE_0_NOTES.md)
PAYOUT_ADDRESS=            # X Layer address receiving USDT
OKX_API_KEY=              # from https://web3.okx.com/onchain-os/dev-portal
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# --- Media (Venice) — wired in Phase 2 ---
VENICE_API_KEY=            # child key with spend cap sized to campaign media budget
MEDIA_BUDGET_USD=0.60      # per-job hard cap, enforced via /video/quote before any generation (3x $0.18 clips + TTS)
VIDEO_MODEL=longcat-distilled-text-to-video   # cheapest capable 720p clip model ($0.18/10s); swap via config
VOICE_MODEL=tts-kokoro     # Venice TTS
VOICE=af_bella             # warm voice preset

# --- Script generation (Anthropic) ---
ANTHROPIC_API_KEY=         # from https://console.anthropic.com — drives the script stage
SCRIPT_MODEL=claude-sonnet-5   # optional override for the script-writing model
